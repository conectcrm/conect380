{
  "name": "conectcrm",
  "version": "1.0.0",
  "description": "Sistema CRM com padronização automática de telas",
  "main": "index.js",
  "scripts": {
    "setup": "node scripts/setup.js",
    "generate:page": "node scripts/generators/generatePage.js",
    "generate:service": "node scripts/generators/generateService.js",
    "generate:types": "node scripts/generators/generateTypes.js",
    "setup:dev": "npm install && cd frontend-web && npm install && cd ../backend && npm install",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "cd frontend-web && npm start",
    "start:admin-web": "cd admin-web && npm run dev",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend-web && npm test",
    "test:e2e": "playwright test",
    "test:e2e:clientes": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/clientes-modal-profile-navigation.spec.ts e2e/clientes-filters-bulk-selection.spec.ts e2e/clientes-states-ux.spec.ts e2e/clientes-cadastro-perfil-validation.spec.ts --project=chromium --reporter=list",
    "test:e2e:clientes:ux": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/clientes-states-ux.spec.ts --project=chromium --reporter=list",
    "test:e2e:clientes:cadastro-perfil": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/clientes-cadastro-perfil-validation.spec.ts --project=chromium --reporter=list",
    "test:e2e:clientes:evidencias": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/clientes-qa-evidence.spec.ts --project=chromium --reporter=list",
    "qa:crm020:signoff:init": "node scripts/qa/init-crm020-signoff-session.mjs",
    "qa:crm020:signoff:seed:local": "node scripts/qa/seed-crm020-signoff-local.mjs",
    "qa:crm020:signoff:pendings:complete": "node scripts/qa/complete-crm020-signoff-pendings.mjs",
    "qa:crm020:signoff:report": "node scripts/qa/generate-crm020-signoff-report.mjs",
    "qa:crm020:signoff:validate": "node scripts/qa/validate-crm020-signoff.mjs",
    "qa:crm020:signoff:close": "node scripts/qa/close-crm020-signoff.mjs",
    "qa:crm020:signoff:close:allow-pending": "node scripts/qa/close-crm020-signoff.mjs --allow-pending",
    "qa:crm020:signoff:close:apply": "node scripts/qa/close-crm020-signoff.mjs --apply-checklist",
    "qa:crm020:signoff:apply": "node scripts/qa/apply-crm020-signoff.mjs",
    "qa:crm020:signoff:finalize": "node scripts/qa/finalize-crm020-signoff.mjs",
    "test:e2e:pipeline-ui": "playwright test e2e/pipeline-stage-validation.spec.ts e2e/pipeline-loss-validation.spec.ts --project=chromium --reporter=list",
    "test:e2e:comercial:core": "set PLAYWRIGHT_WEB_SERVER=1 && playwright test e2e/pipeline-stage-validation.spec.ts e2e/pipeline-loss-validation.spec.ts e2e/pipeline-proposta-rascunho.spec.ts e2e/propostas-bloqueio-sem-itens.spec.ts e2e/propostas-visualizacao-modal.spec.ts e2e/propostas-acoes-status.spec.ts e2e/propostas-whatsapp-validacao.spec.ts e2e/propostas-acoes-sucesso.spec.ts e2e/propostas-automacao-fluxo.spec.ts e2e/propostas-principal-sync.spec.ts --project=chromium --reporter=list",
    "test:e2e:billing:admin-guardian-redirects": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/billing-admin-guardian-redirects.spec.ts --project=chromium --reporter=list",
    "test:e2e:billing:critical": "set TEST_E2E_AUTH_MODE=mock && playwright test e2e/billing-self-service.spec.ts e2e/billing-self-service-negative-access.spec.ts e2e/billing-finance-relay-permissions.spec.ts e2e/billing-session-security.spec.ts e2e/billing-admin-guardian-redirects.spec.ts --project=chromium --reporter=list",
    "test:e2e:guardian:billing:governance": "playwright test e2e/guardian-billing-governance.spec.ts --project=chromium --reporter=list",
    "test:e2e:mobile:guard": "playwright test e2e/mobile-responsiveness-smoke.spec.ts e2e/mobile-drawer-profile.spec.ts --project=chromium --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "build:all": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend-web && npm run build",
    "build:admin-web": "cd admin-web && npm run build",
    "type-check:admin-web": "cd admin-web && npm run type-check",
    "deploy:admin-web": "powershell -ExecutionPolicy Bypass -File scripts/deploy-admin-web.ps1",
    "check:encoding": "node scripts/checkEncoding.js",
    "validate:release:vendas:core": "node scripts/ci/validate-sales-release-mode.mjs --mode core --frontend-env frontend-web/.env.example --backend-env backend/.env.production.example",
    "validate:release:vendas:full": "node scripts/ci/validate-sales-release-mode.mjs --mode full --frontend-env frontend-web/.env.full.example --backend-env backend/.env.production.full.example",
    "preflight:go-live:vendas:core": "node scripts/ci/preflight-sales-go-core.mjs",
    "preflight:go-live:vendas:full": "node scripts/ci/preflight-sales-go-full.mjs",
    "monitor:go-live:vendas-financeiro": "powershell -ExecutionPolicy Bypass -File scripts/monitor-pos-go-live-vendas-financeiro.ps1 -BaseUrl http://localhost:3001 -IntervalSeconds 10 -MonitorExpectedIntervalSeconds 300 -MaxCycles 2 -SkipAlertas",
    "monitor:go-live:vendas-financeiro:48h": "powershell -ExecutionPolicy Bypass -File scripts/monitor-pos-go-live-vendas-financeiro.ps1 -BaseUrl http://localhost:3001 -IntervalSeconds 300 -MonitorExpectedIntervalSeconds 300 -DurationHours 48 -SkipAlertas",
    "monitor:opp304:piloto": "powershell -ExecutionPolicy Bypass -File scripts/monitor-opp304-piloto-48h.ps1",
    "monitor:opp304:piloto:dryrun": "powershell -ExecutionPolicy Bypass -File scripts/monitor-opp304-piloto-48h.ps1 -DryRun -MaxCycles 1",
    "monitor:opp304:piloto:quick": "powershell -ExecutionPolicy Bypass -File scripts/monitor-opp304-piloto-48h.ps1 -IntervalSeconds 10 -MaxCycles 2",
    "test:opp304:piloto": "powershell -ExecutionPolicy Bypass -File scripts/test-opp304-piloto-lifecycle.ps1",
    "test:opp304:piloto:dryrun": "powershell -ExecutionPolicy Bypass -File scripts/test-opp304-piloto-lifecycle.ps1 -DryRun",
    "test:opp305:stale": "powershell -ExecutionPolicy Bypass -File scripts/test-opp305-stale-quality.ps1",
    "test:opp305:homolog": "powershell -ExecutionPolicy Bypass -File scripts/test-opp305-stale-homologacao.ps1",
    "test:opp305:homolog:dryrun": "powershell -ExecutionPolicy Bypass -File scripts/test-opp305-stale-homologacao.ps1 -DryRun",
    "sync:audit": "powershell -ExecutionPolicy Bypass -File scripts/git/sync-safe.ps1",
    "sync:apply": "powershell -ExecutionPolicy Bypass -File scripts/git/sync-safe.ps1 -Apply",
    "sync:apply:force": "powershell -ExecutionPolicy Bypass -File scripts/git/sync-safe.ps1 -Apply -AllowHighRisk",
    "sync:harden": "powershell -ExecutionPolicy Bypass -File scripts/git/harden-git-sync.ps1",
    "branch:health": "powershell -ExecutionPolicy Bypass -File scripts/git/branch-health.ps1",
    "branch:health:prune": "powershell -ExecutionPolicy Bypass -File scripts/git/branch-health.ps1 -PruneFetch",
    "branch:worktree:new": "powershell -ExecutionPolicy Bypass -File scripts/git/new-isolated-worktree.ps1",
    "runtime:prepare": "powershell -ExecutionPolicy Bypass -File scripts/git/new-runtime-clone.ps1",
    "runtime:deps:install": "powershell -ExecutionPolicy Bypass -File scripts/git/install-runtime-deps.ps1",
    "runtime:sync": "powershell -ExecutionPolicy Bypass -File scripts/git/sync-runtime-clone.ps1",
    "runtime:sync:allow-divergent": "powershell -ExecutionPolicy Bypass -File scripts/git/sync-runtime-clone.ps1 -AllowDivergentSource",
    "runtime:start:all": "powershell -ExecutionPolicy Bypass -File scripts/git/invoke-runtime-command.ps1 -SyncFirst -CommandLine \"npm run start:all\"",
    "runtime:start:backend": "powershell -ExecutionPolicy Bypass -File scripts/git/invoke-runtime-command.ps1 -SyncFirst -CommandLine \"npm run start:backend\"",
    "runtime:start:frontend": "powershell -ExecutionPolicy Bypass -File scripts/git/invoke-runtime-command.ps1 -SyncFirst -CommandLine \"npm run start:frontend\"",
    "runtime:start:admin-web": "powershell -ExecutionPolicy Bypass -File scripts/git/invoke-runtime-command.ps1 -SyncFirst -CommandLine \"npm run start:admin-web\"",
    "runtime:start:guardian-web": "powershell -ExecutionPolicy Bypass -File scripts/git/invoke-runtime-command.ps1 -SyncFirst -CommandLine \"npm --prefix guardian-web run dev\"",
    "branch:remote-health": "powershell -ExecutionPolicy Bypass -File scripts/git/remote-branch-health.ps1",
    "branch:remote-health:prune": "powershell -ExecutionPolicy Bypass -File scripts/git/remote-branch-health.ps1 -PruneFetch"
  },
  "keywords": [
    "crm",
    "padronização",
    "automação",
    "segurança",
    "auditoria"
  ],
  "author": "ConectCRM Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "concurrently": "^8.2.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^20.0.0",
    "chalk": "^4.1.2",
    "socket.io-client": "^4.8.1"
  }
}
