# ============================================
# FLUXO DE VENDAS - BASELINE GO FULL
# ============================================
# Arquivo de referencia para validar guardrails de release no modo Full.
# Ajuste conforme seu ambiente real de deploy.

NODE_ENV=production

# Bypass de gateway deve permanecer desligado.
PAGAMENTOS_GATEWAY_ALLOW_UNIMPLEMENTED=false

# Providers habilitados no backend (alinhar com frontend).
# Valores aceitos: stripe, mercado_pago, pagseguro
PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=stripe,mercado_pago

# Tenant owner policy (fallback)
# IDs UUID separados por virgula ou ponto e virgula.
# Exemplo: PLATFORM_OWNER_EMPRESA_IDS=250cc3ac-617b-4d8b-be6e-b14901e4edde
PLATFORM_OWNER_EMPRESA_IDS=
