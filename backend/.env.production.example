# ============================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO AWS
# ============================================

# ⚠️ IMPORTANTE: 
# Este arquivo deve ser configurado no AWS Secrets Manager
# ou Systems Manager Parameter Store em produção.
# NUNCA commite este arquivo com valores reais!

# ============================================
# Banco de Dados - AWS RDS PostgreSQL
# ============================================
DATABASE_HOST=conectcrm-db.xxxxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_USERNAME=conectcrm_admin
DATABASE_PASSWORD=<GERADO_PELO_RDS>
DATABASE_NAME=conectcrm_production

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=<GERAR_NOVO_SECRET_256_BITS>
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=<GERAR_NOVO_REFRESH_SECRET_256_BITS>
JWT_REFRESH_EXPIRES_IN=7d
# MFA administrativo obrigatório em produção
AUTH_ADMIN_MFA_REQUIRED=true
AUTH_MFA_DEV_FALLBACK_ENABLED=false

# ============================================
# Configurações da Aplicação
# ============================================
APP_PORT=3001
APP_ENV=production
NODE_ENV=production
APP_RELEASE_VERSION=2026.03.09

# ============================================
# CORS Origins (URLs de produção)
# ============================================
CORS_ORIGINS=https://app.conectcrm.com.br,https://www.conectcrm.com.br

# ============================================
# Configurações de Upload - AWS S3
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DEST=./uploads
AWS_S3_BUCKET=conectcrm-uploads
AWS_REGION=us-east-1

# ============================================
# Email - AWS SES ou SMTP
# ============================================
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=<AWS_SES_SMTP_USERNAME>
SMTP_PASS=<AWS_SES_SMTP_PASSWORD>
# Compatibilidade com integrações legadas
SMTP_PASSWORD=<AWS_SES_SMTP_PASSWORD>
EMAIL_FROM=noreply@conectcrm.com.br
EMAIL_FROM_NAME=Conect CRM

# ============================================
# URL Frontend
# ============================================
FRONTEND_URL=https://app.conectcrm.com.br

# ============================================
# WHATSAPP BUSINESS CLOUD API
# ============================================
WHATSAPP_ACCESS_TOKEN=<TOKEN_PRODUCAO>
WHATSAPP_PHONE_NUMBER_ID=<PHONE_ID_PRODUCAO>
WHATSAPP_BUSINESS_ACCOUNT_ID=<BUSINESS_ACCOUNT_ID>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<WEBHOOK_TOKEN_SEGURO>

# ============================================
# OPENAI (para IA)
# ============================================
OPENAI_API_KEY=<SUA_CHAVE_OPENAI>
OPENAI_MODEL=gpt-4o-mini

# ============================================
# ANTHROPIC CLAUDE
# ============================================
ANTHROPIC_API_KEY=<SUA_CHAVE_ANTHROPIC>
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# Monitoramento e Logs
# ============================================
LOG_LEVEL=info
SENTRY_DSN=<OPTIONAL_SENTRY_DSN>

# ============================================
# Cache e Performance
# ============================================
REDIS_HOST=<OPTIONAL_ELASTICACHE_ENDPOINT>
REDIS_PORT=6379
REDIS_PASSWORD=<OPTIONAL_REDIS_PASSWORD>

# ============================================
# Core Admin capability policy
# ============================================
# Recomendacao de producao: manter tudo false, liberando apenas por excecao formal.
CORE_ADMIN_ALLOW_BREAK_GLASS_REQUEST_CREATION=false
CORE_ADMIN_ALLOW_MANUAL_BILLING_DUE_DATE_CYCLE=false
CORE_ADMIN_ALLOW_PLAN_DELETION=false
CORE_ADMIN_ALLOW_DIRECT_ACCESS_RECERTIFICATION=false
CORE_ADMIN_ALLOW_COMPANY_MODULE_MANAGEMENT=false
CORE_ADMIN_POLICY_ALERT_EMAILS=operacao@conect360.com.br,seguranca@conect360.com.br
# Em producao, manter false.
CORE_ADMIN_RUNTIME_ALERT_RUN_IN_TEST=false

# Tenant owner policy (producao)
# IDs UUID separados por virgula ou ponto e virgula.
# Recomendacao: manter flag no banco e usar esta variavel como fallback operacional.
# Exemplo: PLATFORM_OWNER_EMPRESA_IDS=250cc3ac-617b-4d8b-be6e-b14901e4edde
PLATFORM_OWNER_EMPRESA_IDS=
# Em producao, manter true para bloquear admin quando owner nao estiver configurado.
PLATFORM_OWNER_ENFORCE_WHEN_EMPTY=true

# Transicao do admin consolidado no app principal (sem redirecionamento para guardian).
CORE_ADMIN_LEGACY_TRANSITION_MODE=legacy
CORE_ADMIN_LEGACY_READ_ONLY=false
CORE_ADMIN_LEGACY_CANARY_PERCENT=0

# Swagger restrito do Core Admin (governanca interna da plataforma).
# Em producao, habilitar somente com credenciais fortes.
CORE_ADMIN_DOCS_ENABLED=false
CORE_ADMIN_DOCS_PATH=core-admin-docs
CORE_ADMIN_DOCS_USER=
CORE_ADMIN_DOCS_PASSWORD=

# Self-signup: normaliza novos tenants no lifecycle moderno da Pipeline.
# Recomendado em producao: true.
SELF_SIGNUP_ENABLE_OPORTUNIDADES_LIFECYCLE=true

# ============================================
# DASHBOARD V2 - INSIGHTS FINANCEIROS
# ============================================
# Threshold (%) minimo de recebimento para considerar alerta.
DASHBOARD_V2_FINANCEIRO_RECEBIMENTO_ALERT_THRESHOLD=75
# Fator de pressao de caixa: alerta quando saldo < atraso * fator.
DASHBOARD_V2_FINANCEIRO_CAIXA_ALERT_FACTOR=1
# Limite maximo de insights financeiros exibidos por recorte.
DASHBOARD_V2_FINANCEIRO_INSIGHTS_LIMIT=5

# ============================================
# PAGAMENTOS - GATEWAY FEATURE GATE
# ============================================
# Lista de providers habilitados por ambiente (separados por virgula)
# Valores aceitos: stripe, mercado_pago, pagseguro
PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=mercado_pago

# Bypass global (usar apenas em dev/homologacao)
# Em producao, mantenha false e habilite via lista acima
PAGAMENTOS_GATEWAY_ALLOW_UNIMPLEMENTED=false

# Credenciais Mercado Pago da PLATAFORMA PROPRIETARIA (obrigatorio quando mercado_pago estiver habilitado)
# Essas credenciais recebem as mensalidades SaaS dos clientes do Conect360.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# MOCK somente para dev/homologacao. Em producao deve permanecer false.
MERCADO_PAGO_MOCK=false

# ============================================
# FINANCEIRO ESSENCIAL (SEM NF-e / BOLETO)
# ============================================
# Em release inicial, manter false para bloquear fiscal oficial e boleto.
FINANCEIRO_FISCAL_DOCS_ENABLED=false
FINANCEIRO_BOLETO_ENABLED=false
FINANCEIRO_MVP_MODE=true

# ============================================
# FATURAMENTO FISCAL - INTEGRACAO OFICIAL
# ============================================
# Provider fiscal principal (ex.: fiscal_stub_local, fiscal_oficial)
FISCAL_PROVIDER=fiscal_stub_local

# Em producao, recomendamos true para bloquear emissao sem provider oficial
FISCAL_REQUIRE_OFFICIAL_PROVIDER=true

# Habilita integracao HTTP do provider oficial
FISCAL_OFFICIAL_HTTP_ENABLED=false

# Base URL do provider oficial (obrigatorio quando HTTP habilitado)
FISCAL_OFFICIAL_BASE_URL=

# Token opcional para autenticacao Bearer no provider oficial
FISCAL_OFFICIAL_API_TOKEN=

# Timeout de requisicao HTTP para operacoes fiscais (ms)
FISCAL_OFFICIAL_TIMEOUT_MS=15000

# Retries para falhas transientes (timeout, 429, 5xx, rede)
FISCAL_OFFICIAL_MAX_RETRIES=1
FISCAL_OFFICIAL_RETRY_DELAY_MS=500

# Paths customizaveis do provider oficial (opcional)
FISCAL_OFFICIAL_EMIT_PATH=/documentos/emitir
FISCAL_OFFICIAL_STATUS_PATH=/documentos/status
FISCAL_OFFICIAL_FINALIZE_PATH=/documentos/operacao-final
FISCAL_OFFICIAL_HEALTH_PATH=/health

# Metodo HTTP por operacao (GET, POST, PUT, PATCH)
FISCAL_OFFICIAL_EMIT_METHOD=POST
FISCAL_OFFICIAL_STATUS_METHOD=GET
FISCAL_OFFICIAL_FINALIZE_METHOD=POST
FISCAL_OFFICIAL_HEALTH_METHOD=GET

# Header para correlacao de requisicoes no provider oficial (opcional)
FISCAL_OFFICIAL_CORRELATION_HEADER=X-Correlation-Id

# Valida contrato minimo do retorno do provider (status/codigo e identificacao na emissao)
FISCAL_OFFICIAL_STRICT_RESPONSE=true

# Aliases de campos no retorno do provider oficial (opcional, separados por virgula/ponto e virgula)
# Aceita path aninhado, ex.: data.status;retorno.situacaoFiscal
FISCAL_OFFICIAL_RESPONSE_ROOT_PATHS=result,data,documento
FISCAL_OFFICIAL_RESPONSE_STATUS_KEYS=status,situacao,state,resultado,statusDocumento,fiscalStatus
FISCAL_OFFICIAL_RESPONSE_CODE_KEYS=codigoRetorno,codigo,code,statusCode
FISCAL_OFFICIAL_RESPONSE_NUMBER_KEYS=numeroDocumento,numero,documentNumber,invoiceNumber
FISCAL_OFFICIAL_RESPONSE_SERIE_KEYS=serie,series
FISCAL_OFFICIAL_RESPONSE_ACCESS_KEY_KEYS=chaveAcesso,chave,accessKey,chave_acesso
FISCAL_OFFICIAL_RESPONSE_PROTOCOL_KEYS=protocolo,protocol,authorizationProtocol
FISCAL_OFFICIAL_RESPONSE_BATCH_KEYS=loteId,lote,batchId
FISCAL_OFFICIAL_RESPONSE_MESSAGE_KEYS=mensagem,message,descricao,detail,details
FISCAL_OFFICIAL_RESPONSE_REFERENCE_KEYS=referenciaExterna,externalReference,external_reference

# Seguranca para webhook de callback fiscal oficial
FISCAL_OFFICIAL_WEBHOOK_SECRET=
FISCAL_OFFICIAL_WEBHOOK_ALLOW_INSECURE=false

