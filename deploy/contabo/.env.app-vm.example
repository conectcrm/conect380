# ------------------------------------------------------------
# APP VM - EXAMPLE ENVIRONMENT
# Copy to: deploy/contabo/.env.app-vm
# ------------------------------------------------------------
# VPS references:
# - srv_app: 147.93.3.241
# - srv_api: 147.93.3.190

# Release metadata
APP_RELEASE_VERSION=2026.03.15

# Frontend build-time URLs
REACT_APP_API_URL=https://api.conect360.com
REACT_APP_WS_URL=wss://api.conect360.com
REACT_APP_WEBSOCKET_URL=
REACT_APP_GUARDIAN_WEB_URL=https://guardian.conect360.com
VITE_GUARDIAN_API_URL=https://api.conect360.com
REACT_APP_PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=mercado_pago
REACT_APP_PAGAMENTOS_GATEWAY_ALLOW_UNIMPLEMENTED=false

# Application
NODE_ENV=production
APP_ENV=production
APP_PORT=3001
FRONTEND_URL=https://conect360.com
CORS_ORIGINS=https://conect360.com,https://www.conect360.com,https://guardian.conect360.com

# Database (DB VM private IP)
DATABASE_HOST=147.93.3.190
DATABASE_PORT=5432
DATABASE_USERNAME=conectcrm_admin
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=conectcrm_production
DATABASE_SSL=false

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# Security
AUTH_ADMIN_MFA_REQUIRED=true
AUTH_MFA_DEV_FALLBACK_ENABLED=false
SELF_SIGNUP_ENABLE_OPORTUNIDADES_LIFECYCLE=true

# Guardian policy
GUARDIAN_ALLOW_BREAK_GLASS_REQUEST_CREATION=false
GUARDIAN_ALLOW_MANUAL_BILLING_DUE_DATE_CYCLE=false
GUARDIAN_ALLOW_PLAN_DELETION=false
GUARDIAN_ALLOW_DIRECT_ACCESS_RECERTIFICATION=false
GUARDIAN_ALLOW_COMPANY_MODULE_MANAGEMENT=false
GUARDIAN_POLICY_ALERT_EMAILS=operacao@conect360.com,seguranca@conect360.com
PLATFORM_OWNER_EMPRESA_IDS=
PLATFORM_OWNER_ENFORCE_WHEN_EMPTY=true
GUARDIAN_LEGACY_TRANSITION_MODE=legacy
GUARDIAN_LEGACY_READ_ONLY=false
GUARDIAN_LEGACY_CANARY_PERCENT=0

# SMTP (optional but recommended)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_FROM=noreply@conect360.com

# Integrations (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Gateway feature flags
PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=mercado_pago
PAGAMENTOS_GATEWAY_ALLOW_UNIMPLEMENTED=false

# Mercado Pago (obrigatorio quando mercado_pago estiver habilitado)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Em producao deve permanecer false.
MERCADO_PAGO_MOCK=false
