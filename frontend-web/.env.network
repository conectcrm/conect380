# Configurações da aplicação
REACT_APP_NAME=ConectCRM
REACT_APP_VERSION=1.0.0
REACT_APP_MVP_MODE=false
REACT_APP_FINANCEIRO_BOLETO_ENABLED=true
REACT_APP_PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=mercado_pago

# Configurações de desenvolvimento
REACT_APP_ENV=development
PORT=3000

# Permitir acesso externo (0.0.0.0 = todas interfaces de rede)
HOST=0.0.0.0

# Configurações do Build
SKIP_PREFLIGHT_CHECK=true
GENERATE_SOURCEMAP=false
TSC_COMPILE_ON_ERROR=true

# Configurações de tema padrão
REACT_APP_DEFAULT_THEME=light
REACT_APP_DEFAULT_LANGUAGE=pt-BR

# Configurações de upload
REACT_APP_MAX_FILE_SIZE=10485760

# URLs externas (para futuras integrações)
REACT_APP_SUPPORT_URL=
REACT_APP_DOCS_URL=
