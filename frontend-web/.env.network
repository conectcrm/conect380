REACT_APP_WS_URL=ws://172.23.192.1:3001
REACT_APP_EMAIL_SERVER_URL=http://172.23.192.1:3800

# Configurações de E-mail
REACT_APP_EMAIL_PROVIDER=gmail
REACT_APP_EMAIL_USER=conectcrm@gmail.com
