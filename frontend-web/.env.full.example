# ============================================
# FLUXO DE VENDAS - BASELINE GO FULL
# ============================================
# Arquivo de referencia para validar guardrails de release no modo Full.
# Ajuste conforme seu ambiente real de homolog/producao.

# GO Full exige MVP desativado para liberar contratos/faturamento no frontend.
# Neste estagio, emissao fiscal (NF-e/NFS-e) permanece fora do escopo.
REACT_APP_MVP_MODE=false
REACT_APP_FINANCEIRO_FISCAL_DOCS_ENABLED=false
REACT_APP_FINANCEIRO_BOLETO_ENABLED=true

# No modo Full, a estrutura avancada de categorias pode ser habilitada.
REACT_APP_CATALOGO_CATEGORIAS_AVANCADAS_ENABLED=true

# Catalogo flexivel via API nova.
# Em Full, mantenha habilitado apenas para tenants validados em piloto.
REACT_APP_CATALOGO_API_ENABLED=true
REACT_APP_CATALOGO_API_TENANTS=

# Painel administrativo isolado Guardian (superadmin/governanca).


# Bypass de gateway deve permanecer desligado.
REACT_APP_PAGAMENTOS_GATEWAY_ALLOW_UNIMPLEMENTED=false

# Providers habilitados visualmente no frontend (alinhar com backend).
# Baseline Full atual homologado: mercado_pago.
# Valores aceitos: stripe, mercado_pago, pagseguro
REACT_APP_PAGAMENTOS_GATEWAY_ENABLED_PROVIDERS=mercado_pago

# PDF de faturas habilitado no modo Full.
REACT_APP_FATURAMENTO_PDF_ENABLED=true
